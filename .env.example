# Copy to .env:   cp .env.example .env
# These local-dev defaults match docker-compose.yml — non-secret, safe to commit.
#
# Injected data sources (CLAUDE.md Rule 4): point these anywhere — local Docker,
# a hosted Supabase, or a second domain — without changing any code.
DOC_STORE_DSN=postgresql://rag:rag@localhost:5432/docs
SQL_STORE_DSN=postgresql://rag:rag@localhost:5433/guestpad

# Embedding model (fastembed — local, ONNX, no API key). 384 dimensions.
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Phase 1+ (the LLM agents). NOT needed for Phase 0 ingestion.
# ANTHROPIC_API_KEY=
# LLM_MODEL=claude-opus-4-8       # answer synthesis + text-to-SQL (default)
# ROUTER_MODEL=claude-opus-4-8    # supervisor classifier; claude-haiku-4-5 is cheaper + faster
